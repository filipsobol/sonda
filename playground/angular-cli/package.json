{
	"name": "playground-angular-cli",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "pnpm run build:angular-cli && pnpm run build:subproject && pnpm run sonda",
		"build:angular-cli": "ng build angular-cli",
		"build:subproject": "ng build subproject",
		"watch": "ng build --watch --configuration development",
		"serve:ssr:angular-cli": "node dist/angular-cli/server/server.mjs",
		"serve:ssr:subproject": "node dist/subproject/server/server.mjs",
		"sonda": "sonda-angular --projects=angular-cli --format=html"
	},
	"dependencies": {
		"@angular/animations": "^21.2.1",
		"@angular/common": "^21.2.1",
		"@angular/compiler": "^21.2.1",
		"@angular/core": "^21.2.1",
		"@angular/forms": "^21.2.1",
		"@angular/platform-browser": "^21.2.1",
		"@angular/platform-browser-dynamic": "^21.2.1",
		"@angular/platform-server": "^21.2.1",
		"@angular/router": "^21.2.1",
		"@angular/ssr": "^21.2.0",
		"express": "^5.2.1",
		"rxjs": "~7.8.2",
		"tslib": "^2.8.1",
		"zone.js": "~0.16.1"
	},
	"devDependencies": {
		"@angular/build": "^21.2.0",
		"@angular/cli": "^21.2.0",
		"@angular/compiler-cli": "^21.2.1",
		"@types/express": "^5.0.6",
		"@types/jasmine": "~6.0.0",
		"@types/node": "^25.3.3",
		"jasmine-core": "~6.1.0",
		"karma": "~6.4.4",
		"karma-chrome-launcher": "~3.2.0",
		"karma-coverage": "~2.2.1",
		"karma-jasmine": "~5.1.0",
		"karma-jasmine-html-reporter": "~2.2.0",
		"sonda": "workspace:^",
		"typescript": "~5.9.3"
	}
}
